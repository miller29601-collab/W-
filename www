from fastapi import FastAPI
from pydantic import BaseModel
app = FastAPI 
tasks = []
class Task(BaseModel):
    title: str
@app.post("/tasks")
def add(task: Task):
    new_task = {
        "id": len(tasks) + 1,
        "title": title
        "completed": False
    }
    tasks.append(new_task)
    return new_task

@app.get("/tasks")
def get_all:  
    return Task
@app.delete("/tasks/{task_id}")
def delete_task(task_id: int):
    tasks = [t for t in tasks if t["id"] != task_id]
    return {"status": "ok"}
